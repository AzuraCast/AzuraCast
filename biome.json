{
    "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "includes": [
            "**/*.vue",
            "**/*.ts",
            "**/*.tsx",
            "**/*.mts",
            "**/*.cts",
            "!!**/*.d.ts"
        ],
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "style": {
                "useImportType": "off",
                "noNonNullAssertion": "off"
            },
            "suspicious": {
                "noExplicitAny": "off"
            }
        }
    },
    "javascript": {
        "formatter": { "quoteStyle": "double" },
        "globals": []
    },
    "overrides": [
        {
            "includes": ["*.vue", "**/*.vue"],
            "javascript": { "globals": [] },
            "linter": {
                "rules": {
                    "correctness": {
                        "noUnusedVariables": "off",
                        "noUnusedImports": "off",
                        "noVueDuplicateKeys": "off"
                    },
                    "style": {
                        "useVueMultiWordComponentNames": "off"
                    }
                }
            }
        },
        {
            "includes": [
                "**/*.ts",
                "**/*.tsx",
                "**/*.mts",
                "**/*.cts",
                "**/*.vue"
            ]
        },
        {
            "includes": ["**/*.js", "**/*.jsx", "**/*.cjs", "**/*.mjs"],
            "javascript": { "globals": [] },
            "linter": {
                "rules": {
                    "complexity": {
                        "useArrayFind": "off",
                        "useLiteralKeys": "off",
                        "useOptionalChain": "off"
                    },
                    "style": {
                        "useConsistentEnumValueType": "off",
                        "useReadonlyClassProperties": "off"
                    },
                    "suspicious": {
                        "useArraySortCompare": "off",
                        "useAwait": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": { "source": { "organizeImports": "on" } }
    }
}
