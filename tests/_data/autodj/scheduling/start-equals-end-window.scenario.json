{
  "description": "A 'play once' per schedule (start_time == end_time) is eligible from the start time through the 15-minute grace window, and ineligible before it and after the grace window ends.",
  "modes": [
    "in_memory",
    "integration"
  ],
  "cases": [
    {
      "name": "at-start-plays",
      "now": "2018-01-15T06:00:00+00:00",
      "expect_should_play": {
        "drop": true
      }
    },
    {
      "name": "within-grace-window-plays",
      "now": "2018-01-15T06:10:00+00:00",
      "expect_should_play": {
        "drop": true
      }
    },
    {
      "name": "after-grace-window-does-not-play",
      "now": "2018-01-15T06:20:00+00:00",
      "expect_should_play": {
        "drop": false
      }
    },
    {
      "name": "before-start-does-not-play",
      "now": "2018-01-15T05:50:00+00:00",
      "expect_should_play": {
        "drop": false
      }
    }
  ]
}
